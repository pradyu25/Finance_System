# Application
APP_NAME="Finance Intelligence System"
APP_VERSION="1.0.0"
DEBUG=true

# Database
# SQLite — zero config, works out of the box
DATABASE_URL="sqlite+aiosqlite:///./finance.db"

# PostgreSQL — uncomment and fill in to switch
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/finance_db"

# JWT
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE-ME-to-a-long-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Seed script uses these to create the first admin account
FIRST_ADMIN_EMAIL="admin@finance.io"
FIRST_ADMIN_PASSWORD="Admin@1234"
FIRST_ADMIN_NAME="System Admin"
